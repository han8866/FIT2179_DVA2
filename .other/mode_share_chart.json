{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Primary Transport Mode Share in Victoria",
  "width": 320,
  "height": 200,
  "data": {
    "url": "trim_trips_vista_2012_2020_lga_v1.csv"
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 4,
    "tooltip": true
  },
  "encoding": {
    "x": {
      "aggregate": "count",
      "type": "quantitative",
      "title": "Number of Trips",
      "axis": {"grid": true}
    },
    "y": {
      "field": "linkmode",
      "type": "nominal",
      "title": "Transport Mode",
      "sort": "-x"
    },
    "color": {
      "field": "linkmode",
      "type": "nominal",
      "legend": null,
      "scale": {"scheme": "category10"}
    }
  }
}