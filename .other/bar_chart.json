{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
"width": "container",  
"height": {"step": 30},
  "title": "Transport Mode by Trip Purpose",
  "data": {
    "url": "trim_trips_vista_2012_2020_lga_v1.csv"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "aggregate": "count",
      "type": "quantitative",
      "stack": "normalize",
      "title": "Percentage of Trips",
      "axis": {"format": "%"}
    },
    "y": {
      "field": "trippurp",
      "type": "nominal",
      "title": "Purpose",
      "sort": "-x"
    },
    "color": {
      "field": "linkmode",
      "type": "nominal",
      "title": "Transport Mode"
    },
    "tooltip": [
      {"field": "trippurp", "type": "nominal", "title": "Purpose"},
      {"field": "linkmode", "type": "nominal", "title": "Mode"},
      {"aggregate": "count", "type": "quantitative", "title": "Total Records"}
    ]
  }
}