{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Punchcard Timeline: Transport Mode vs Time of Day",
  "width": "container",
  "height": 350,
  "data": {
    "url": "data/A_database_trips_vista_2012_2020_lga_v1.csv"
  },
  "transform": [
    {
      "filter": "datum.starthour != null"
    },
    {
      "filter": {
        "field": "linkmode",
        "oneOf": ["Vehicle Driver", "Train", "Public Bus", "Walking"]
      }
    }
  ],
  "mark": {
    "type": "circle",
    "opacity": 0.8,
    "stroke": "#ffffff",
    "strokeWidth": 1
  },
  "encoding": {
    "x": {
      "field": "starthour",
      "type": "ordinal", 
      "title": "Time of Day (Hour)",
      "axis": {
        "labelAngle": 0,
        "grid": true
      }
    },
    "y": {
      "field": "linkmode",
      "type": "nominal",
      "title": "Transport Mode",
      "axis": {
        "labelFontSize": 12,
        "grid": true
      }
    },
    "size": {
      "aggregate": "count",
      "type": "quantitative",
      "title": "Volume of Trips",
      "scale": {
        "range": [10, 1500] 
      },
      "legend": {
        "orient": "right",
        "format": "s"
      }
    },
    "color": {
      "field": "linkmode",
      "type": "nominal",
      "legend": null,
      "scale": {
        "domain": ["Vehicle Driver", "Train", "Public Bus", "Walking"],
        "range": ["#e74c3c", "#3498db", "#f39c12", "#2ecc71"]
      }
    },
    "tooltip": [
      {"field": "linkmode", "type": "nominal", "title": "Mode"},
      {"field": "starthour", "type": "ordinal", "title": "Hour of Day"},
      {"aggregate": "count", "type": "quantitative", "title": "Total Trips", "format": ","}
    ]
  }
}