{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Morning Peak Traffic Flow to CBD",
  "width": "container",
  "height": 500,
  "projection": {
    "type": "mercator",
    "center": [144.98, -37.83], 
    "scale": 45000 
  },
  "layer": [
    {
      "data": {
        "url": "data/LGA_POLYGON.json",
        "format": {"type": "topojson", "feature": "LGA_POLYGON"}
      },
      "mark": {
        "type": "geoshape",
        "fill": "#e2e8f0",
        "stroke": "#ffffff",
        "strokeWidth": 1.2
      }
    },
    {
      "data": {
        "url": "data/Chart7_flow_data.csv" 
      },
      "transform": [
        {
          "calculate": "upper(datum.orig_upper)", "as": "orig_upper"
        },
        {
          "lookup": "orig_upper",
          "from": {
            "data": {"url": "data/lga_centroids.csv"},
            "key": "LGA",
            "fields": ["lon", "lat"]
          }
        },
        {
          "filter": "datum.lon != null && datum.lat != null" 
        },
        {
          "calculate": "'Melbourne (CBD)'", "as": "dest_label"
        },
        {
          "calculate": "144.9631", "as": "dest_lon"
        },
        {
          "calculate": "-37.8136", "as": "dest_lat"
        }
      ],
      "mark": {
        "type": "rule",
        "opacity": 0.65,
        "strokeCap": "round"
      },
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "longitude2": {"field": "dest_lon", "type": "quantitative"}, 
        "latitude2": {"field": "dest_lat", "type": "quantitative"}, 
        "size": {
          "field": "traffic_volume",
          "type": "quantitative",
          "scale": {"range": [1, 10]}, 
          "title": "Traffic Volume",
          "legend": {
            "orient": "bottom-right",
            "fillColor": "rgba(255, 255, 255, 0.85)",
            "padding": 10,
            "cornerRadius": 5
          }
        },
        "color": {
          "field": "avg_commute_time",
          "type": "quantitative",
          "scale": {"scheme": "magma"},
          "title": "Avg Time (mins)",
          "legend": {
            "orient": "bottom-right",
            "fillColor": "rgba(255, 255, 255, 0.85)",
            "padding": 10,
            "cornerRadius": 5
          }
        },
        "order": {
          "field": "avg_commute_time",
          "type": "quantitative",
          "sort": "descending" 
        },
        "tooltip": [
          {"field": "orig_upper", "type": "nominal", "title": "From"},
          {"field": "dest_label", "type": "nominal", "title": "To"},
          {"field": "traffic_volume", "type": "quantitative", "title": "Total Morning Trips", "format": ","},
          {"field": "avg_commute_time", "type": "quantitative", "title": "Average Time (mins)", "format": ".1f"}
        ]
      }
    }
  ]
}