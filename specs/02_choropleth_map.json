{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Average Commuting Distance Choropleth Map",
  "width": "container",
  "height": 500,
  "projection": {
    "type": "mercator"
  },
  "data": {
    "url": "data/Chart2_choropleth_data.csv" 
  },
  "transform": [
    {
      "calculate": "trim(upper(datum.origLGA))",
      "as": "orig_upper"
    },
    {
      "lookup": "orig_upper",
      "from": {
        "data": {
          "url": "data/LGA_POLYGON.json",
          "format": {
            "type": "topojson",
            "feature": "LGA_POLYGON"
          }
        },
        "key": "properties.LGA_NAME"
      },
      "as": "geo" 
    }
  ],
  "mark": {
    "type": "geoshape",
    "stroke": "#ffffff",
    "strokeWidth": 0.5
  },
  "encoding": {
    "shape": {
      "field": "geo",
      "type": "geojson"
    },
    "color": {
      "field": "Avg_Distance",
      "type": "quantitative",
      "scale": {
        "type": "log", 
        "scheme": "yelloworangered"
      },
      "title": "Avg Distance (km)",
      "legend": {
        "orient": "left"
      }
    },
    "tooltip": [
      {"field": "origLGA", "type": "nominal", "title": "Origin LGA"},
      {"field": "Avg_Distance", "type": "quantitative", "title": "Average Distance (km)", "format": ".1f"}
    ]
  }
}