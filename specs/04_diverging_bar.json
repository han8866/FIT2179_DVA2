{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Diverging Bar Chart: Car vs Alternative Transport by LGA Distance",
  "width": "container",
  "height": 400,
  "data": {
    "url": "data/A_database_trips_vista_2012_2020_lga_v1.csv"
  },
  "transform": [
    {
      "filter": {
        "field": "origLGA",
        "oneOf": ["MELBOURNE", "YARRA", "BOROONDARA", "MONASH", "KNOX", "YARRA RANGES"]
      }
    },
    {
      "filter": {
        "field": "linkmode",
        "oneOf": ["Vehicle Driver", "Train", "Public Bus", "Walking"]
      }
    },
    {
      "aggregate": [{"op": "count", "as": "trip_count"}],
      "groupby": ["origLGA", "linkmode"]
    },
    {
      "joinaggregate": [{"op": "sum", "field": "trip_count", "as": "total_lga_trips"}],
      "groupby": ["origLGA"]
    },
    {
      "calculate": "datum.trip_count / datum.total_lga_trips",
      "as": "percent"
    },
    {
      "calculate": "datum.linkmode == 'Vehicle Driver' ? datum.percent : -datum.percent",
      "as": "diverging_percent"
    }
  ],
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "y": {
      "field": "origLGA",
      "type": "nominal",
      "title": "Distance from CBD ➔",
      "sort": ["MELBOURNE", "YARRA", "BOROONDARA", "MONASH", "KNOX", "YARRA RANGES"],
      "axis": {
        "labelFontSize": 13,
        "titleFontSize": 14,
        "labelFontWeight": "bold"
      }
    },
    "x": {
      "field": "diverging_percent",
      "type": "quantitative",
      "title": "← Public Transport & Walking  |  Vehicle Driver →",
      "axis": {
        "format": "%",
        "labelExpr": "abs(datum.value)", 
        "titleFontSize": 14
      }
    },
    "color": {
      "field": "linkmode",
      "type": "nominal",
      "title": null,
      "scale": {
        "domain": ["Walking", "Public Bus", "Train", "Vehicle Driver"],
        "range": ["#2ecc71", "#f39c12", "#3498db", "#e74c3c"]
      },
      "legend": {"orient": "top"}
    },
    "order": {
      "field": "linkmode",
      "sort": "ascending"
    },
    "tooltip": [
      {"field": "origLGA", "type": "nominal", "title": "LGA"},
      {"field": "linkmode", "type": "nominal", "title": "Transport Mode"},
      {"field": "percent", "type": "quantitative", "title": "Share of Trips", "format": ".1%"}
    ]
  }
}