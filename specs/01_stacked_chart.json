{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Overall Transport Mode Share",
  "width": "container",
  "height": 100,
  "data": {
    "url": "data/Chart1_overview_data.csv"
  },
  "transform": [
    {
      "joinaggregate": [{"op": "sum", "field": "trip_count", "as": "Total_Trips"}]
    },
    {
      "calculate": "datum.trip_count / datum.Total_Trips",
      "as": "Percentage"
    }
  ],
  "mark": {
    "type": "bar",
    "cornerRadius": 2
  },
  "encoding": {
    "x": {
      "field": "Percentage",
      "type": "quantitative",
      "axis": {
        "format": "%",
        "title": "Percentage of Total Trips",
        "grid": false,
        "domain": false,
        "ticks": false
      }
    },
    "color": {
      "field": "linkmode",
      "type": "nominal",
      "title": "Transport Mode",
      "scale": {
        "domain": ["Walking", "Public Bus", "Train", "Vehicle Driver"],
        "range": ["#2ecc71", "#f39c12", "#3498db", "#e74c3c"]
      },
      "legend": {"orient": "left"}
    },
    "order": {
      "field": "linkmode",
      "sort": "ascending"
    },
    "tooltip": [
      {"field": "linkmode", "type": "nominal", "title": "Mode"},
      {"field": "trip_count", "type": "quantitative", "title": "Total Trips", "format": ","},
      {"field": "Percentage", "type": "quantitative", "title": "Share", "format": ".1%"}
    ]
  }
}