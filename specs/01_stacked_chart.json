{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Overall Transport Mode Share",
  "width": "container",
  "height": 100,
  "data": {
    "url": "data/A_database_trips_vista_2012_2020_lga_v1.csv"
  },
  "transform": [
    {
      "filter": {
        "field": "linkmode",
        "oneOf": ["Vehicle Driver", "Train", "Public Bus", "Walking"]
      }
    }
  ],
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "aggregate": "count",
      "type": "quantitative",
      "stack": "normalize",
      "axis": {
        "format": "%",
        "title": "Percentage of Total Trips",
        "grid": false,
        "domain": false,
        "ticks": false
      }
    },
    "color": {
      "field": "linkmode",
      "type": "nominal",
      "title": "Transport Mode",
      "scale": {
        "domain": ["Vehicle Driver", "Train", "Public Bus", "Walking"],
        "range": ["#e74c3c", "#3498db", "#f39c12", "#2ecc71"] 
      },
      "legend": {
        "orient": "top",
        "title": null
      }
    },
    "order": {
      "field": "linkmode",
      "sort": "ascending"
    }
  }
}